# ============================================================
#  IBM watsonx.ai Smart Farming Advisor Agent — Environment
#  Copy this file to .env and fill in your credentials
# ============================================================

# IBM Cloud API Key (required)
IBM_API_KEY=0-1oI7r6C7wjAT9vqXKBpaWE_poEAtIGa0FONFzbhZTk

# IBM watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=d45b4b6b-443a-4706-8971-6031c18ba467

# IBM watsonx.ai API endpoint (default: Dallas region)
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# IBM Granite Model ID
GRANITE_MODEL_ID=ibm/granite-4-h-small

# Flask Secret Key (change this in production!)
SECRET_KEY=smart-farming-agent-secret-key-change-in-production

# Flask Config
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# OpenWeather API Key (optional — for live weather data)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Default Language (en, hi, pa, te, ta, mr, kn, gu, bn, or, ml)
DEFAULT_LANGUAGE=en

# Mandi Price API (optional — Agmarknet / data.gov.in)
MANDI_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
MANDI_API_KEY=your_data_gov_in_api_key_here
